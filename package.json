{
  "name": "wickra-playground",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A polyglot strategy playground: run one StrategySpec live, side by side, byte-identical in Python, Rust, JS and Go — entirely in the browser (WASM), no backend.",
  "license": "MIT OR Apache-2.0",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . && prettier --check .",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "vue": "^3.5.0",
    "wickra-backtest-wasm": "^0.1.0",
    "wickra-wasm": "^0.9.9"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/eslint-config-typescript": "^14.1.0",
    "eslint": "^9.13.0",
    "eslint-plugin-vue": "^9.30.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^2.1.0",
    "vue-tsc": "^2.1.0"
  }
}
